---
import Base from '@/layouts/Base.astro';
import Seo from '@/components/seo/Seo.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';
import { listTopCategories, getCategory } from '@/lib/queries/categories';
import { listAllProductsForSeo } from '@/lib/queries/products';
import { buildProductPath } from '@/lib/urls';

export const prerender = true;

export async function getStaticPaths() {
  const cats = await listTopCategories();
  return cats.map((c) => ({ params: { category: c.slug } }));
}

const { category } = Astro.params;
const cat = await getCategory(category!);
if (!cat) return Astro.redirect('/404');
const products = (await listAllProductsForSeo()).filter((p) => p.category_slug === category);
---
<Base>
  <Seo slot="head"
    title={`${cat.name} — verified suppliers & prices | ShieldVase`}
    description={cat.description || `Compare ${products.length}+ ${cat.name.toLowerCase()} products from verified Nigerian suppliers on ShieldVase.`}
    path={`/${cat.slug}`} />
  <section class="mx-auto max-w-6xl px-4 py-10">
    <Breadcrumbs items={[{ name: 'Home', href: '/' }, { name: cat.name, href: `/${cat.slug}` }]} />
    <h1 class="mt-4 text-3xl font-bold">{cat.name}</h1>
    {cat.description && <p class="mt-2 text-slate-600 max-w-2xl">{cat.description}</p>}
    <ul class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {products.slice(0, 60).map((p) => (
        <li>
          <a href={buildProductPath({ id: p.id, slug: p.slug, name: p.name, categorySlug: p.category_slug })}
             class="block rounded-lg border border-slate-200 p-4 hover:border-brand">
            <div class="font-medium text-brand-ink">{p.name}</div>
            {p.description && <div class="mt-1 text-sm text-slate-500 line-clamp-2">{p.description}</div>}
          </a>
        </li>
      ))}
    </ul>
  </section>
</Base>
