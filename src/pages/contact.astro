---
import Base from '@/layouts/Base.astro';
import Seo from '@/components/seo/Seo.astro';
import { appUrl } from '@/lib/urls';
export const prerender = true;
---
<Base>
  <Seo slot="head" title="Contact ShieldVase" description="Get in touch with the ShieldVase team." path="/contact" />
  <section class="mx-auto max-w-2xl px-4 py-16">
    <h1 class="text-3xl font-bold">Contact</h1>
    <p class="mt-4 text-slate-600">
      For account, order or vendor questions, use the in-app support routed through admins:
    </p>
    <a href={appUrl('/sme/support')} class="mt-6 inline-block rounded bg-brand text-white px-4 py-2">Open support in app</a>
  </section>
</Base>
