---
import Base from '@/layouts/Base.astro';
import Seo from '@/components/seo/Seo.astro';
export const prerender = true;
---
<Base>
  <Seo slot="head"
    title="About ShieldVase — simplifying B2B procurement in Africa"
    description="ShieldVase aggregates verified vendors across Africa so SMEs, contractors and industrial buyers get transparent pricing, reliable supply and built-in financing."
    path="/about" />
  <article class="mx-auto max-w-3xl px-4 py-16 prose">
    <h1>About ShieldVase</h1>
    <p>ShieldVase is a B2B2C marketplace for raw materials and industrial solutions.</p>
  </article>
</Base>
