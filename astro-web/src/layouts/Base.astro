---
import '../styles/global.css';
import Organization from '@/components/schema/Organization.astro';
import { appUrl } from '@/lib/urls';
export interface Props { bodyClass?: string; }
const { bodyClass = '' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#2563eb" />
    <link rel="icon" type="image/x-icon" href="https://shieldvase-bronze-images.s3.eu-north-1.amazonaws.com/static/assets/ShieldVase%20Logo.ico" />
    <slot name="head" />
    <Organization />
  </head>
  <body class={bodyClass}>
    <header class="border-b border-slate-200">
      <div class="mx-auto max-w-6xl px-4 h-14 flex items-center justify-between">
        <a href="/" class="font-semibold text-brand-ink">ShieldVase</a>
        <nav class="flex items-center gap-6 text-sm">
          <a href="/construction">Construction</a>
          <a href="/chemicals">Chemicals</a>
          <a href="/polymers-and-packaging">Polymers</a>
          <a href="/energy-and-petroleum">Energy</a>
          <a href="/agriculture-and-animal-feed">Agriculture</a>
          <a href={appUrl('/auth')} class="rounded bg-brand text-white px-3 py-1.5">Sign in</a>
        </nav>
      </div>
    </header>
    <main><slot /></main>
    <footer class="mt-16 border-t border-slate-200 py-8 text-sm text-slate-500">
      <div class="mx-auto max-w-6xl px-4 flex items-center justify-between">
        <span>© {new Date().getFullYear()} ShieldVase</span>
        <span><a href={appUrl('/')} class="hover:text-brand">Open marketplace →</a></span>
      </div>
    </footer>
  </body>
</html>
